# =============================================================================
# Linear Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then load it before running:
#   source .env && python linear_arcade.py
# =============================================================================

# OpenAI API key
# Get it at: https://platform.openai.com/api-keys
export OPENAI_API_KEY="sk-proj-..."

# Arcade API key
# Get it at: https://docs.arcade.dev/home/api-keys
export ARCADE_API_KEY="arc_..."

# Your Arcade user ID — the email you used to sign up at https://arcade.dev
export ARCADE_USER_ID="you@example.com"
