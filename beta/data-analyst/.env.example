# Default provider: Vertex AI (Gemini via Google Cloud)
# Requires `gcloud auth application-default login` + a project with Vertex AI enabled.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
# Optional: path to a service-account JSON (otherwise uses Application Default Credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# Required — Daytona sandbox (https://app.daytona.io)
DAYTONA_API_KEY=

# Alternative providers (set LLM_PROVIDER=gemini or openai to use)
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Optional overrides
# LLM_PROVIDER=vertexai      # vertexai | gemini | openai
# MODEL=gemini-3.1-pro-preview
# PORT=8766
